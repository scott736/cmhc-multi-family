---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const title = "Operating Expense Categories & Benchmarks — CMHC";
const description =
  "Line-by-line operating expense benchmarking for CMHC multi-unit underwriting. Property taxes by jurisdiction, insurance, landlord-paid utilities, R&M, management 3–5% EGI, replacement reserves, and total opex 35–50% EGI for purpose-built rental.";

const opexLines = [
  {
    line: "Property taxes",
    perUnit: "$900–$1,800+",
    pctEgi: "5–15%",
    driver: "Jurisdiction + unit count",
    note: "Varies enormously. Toronto ~$1,200/unit, Calgary ~$900/unit, Vancouver ~$1,800/unit. Municipal incentives (Toronto RHSP, Vancouver SRP) can cut this 15–30%.",
  },
  {
    line: "Insurance",
    perUnit: "$200–$400",
    pctEgi: "1.5–3%",
    driver: "Building age, claims history, coverage limits",
    note: "Commercial property and liability combined. Trends up 5–10% per year since 2020. Older buildings, CLT/wood-frame, and seismic zones all carry premiums.",
  },
  {
    line: "Utilities (landlord-paid)",
    perUnit: "$400–$1,800",
    pctEgi: "5–15%",
    driver: "What's included + building systems",
    note: "Tenant-paid excluded. Heat (gas or electric), hot water, common-area electricity, water/sewer. All-inclusive buildings at the top of the range.",
  },
  {
    line: "Repairs & maintenance",
    perUnit: "$600–$1,500",
    pctEgi: "5–10%",
    driver: "Building age, condition, occupancy turnover",
    note: "Includes routine maintenance, minor repairs, landscaping, pest control. Capital items treated separately via replacement reserves.",
  },
  {
    line: "Property management",
    perUnit: "Imputed from EGI",
    pctEgi: "3–5%",
    driver: "Size + service level",
    note: "3% minimum even if self-managed. Full-service third-party management at larger buildings 4–5%.",
  },
  {
    line: "Replacement reserves",
    perUnit: "$250–$500",
    pctEgi: "2–4%",
    driver: "Building age + CMHC dictate",
    note: "CMHC-dictated at submission. Newer buildings at $250/unit; older stock with deferred maintenance at $500/unit or 4%+ EGI.",
  },
  {
    line: "Snow removal / landscaping",
    perUnit: "$100–$300",
    pctEgi: "~1%",
    driver: "Climate + site size",
    note: "Often folded into R&M. Separated out on larger campus sites or where contracted annually.",
  },
  {
    line: "Administrative / other",
    perUnit: "$50–$150",
    pctEgi: "<1%",
    driver: "Accounting, legal, licensing",
    note: "Annual filing, licensing fees, professional services. Typically a small line item.",
  },
];

const totalOpex = [
  {
    archetype: "Newer purpose-built, tenant-pays-all-utilities",
    range: "30–38% EGI",
    note: "Lowest range. Common for recent construction with individual metering and modern systems.",
  },
  {
    archetype: "Mid-age rental, tenant-pays-hydro",
    range: "35–45% EGI",
    note: "Typical range for most CMHC-financed purpose-built rental.",
  },
  {
    archetype: "All-inclusive, older building",
    range: "45–55%+ EGI",
    note: "Landlord-paid heat + hot water + hydro + water. Common for pre-1980 stock.",
  },
];

const cityTaxes = [
  { city: "Toronto", perUnit: "~$1,200", context: "New Multi-Residential Tax Subclass gives 15% reduction for 35 years." },
  { city: "Calgary", perUnit: "~$900", context: "Non-market housing exemption available for qualifying assets." },
  { city: "Vancouver", perUnit: "~$1,800", context: "Highest in Canada for purpose-built rental." },
  { city: "Edmonton", perUnit: "~$1,000", context: "Middle of the range; no material purpose-built incentives." },
  { city: "Ottawa", perUnit: "~$1,100", context: "Affordable Housing CIP grants $6–8K/affordable-unit/yr." },
  { city: "Montréal", perUnit: "~$850", context: "Province-specific valuation roll; SHQ stacking for non-profits." },
];
---

<DefaultLayout title={title} description={description}>
  <div class="bg-obsidian text-foreground">
    {/* HERO */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <Badge variant="outline" className="mb-6 border-star/40 text-star">
          Underwriting · Opex benchmarks
        </Badge>
        <h1 class="text-4xl font-semibold tracking-tight lg:text-6xl">
          Operating expenses — line-by-line benchmarks.
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-muted-foreground">
          CMHC doesn't publish opex assumptions and actuals
          always govern — but there are industry-practice
          ranges that CMHC underwriters regularly accept.
          This page catalogues each line item at both a
          $/unit/year and % of EGI level, with the factors
          that push opex up or down.
        </p>
        <p class="mt-4 max-w-3xl text-lg text-muted-foreground">
          The single biggest driver is what utilities the
          landlord pays. An all-inclusive older building
          can run 15%+ of EGI higher than an individually-
          metered newer asset. The second biggest driver
          is property taxes, which vary by 2× across major
          CMAs. Management and reserves are largely formula-
          driven.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/underwriting/noi-methodology">
            <Button size="lg">NOI methodology</Button>
          </a>
          <a href="/underwriting/opex">
            <Button variant="outline" size="lg">Opex overview</Button>
          </a>
        </div>
      </div>
    </section>

    {/* BIG TABLE */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Line-item benchmarks</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            Each category, both ways to express it.
          </h2>
          <p class="mt-4 text-muted-foreground">
            Two lenses — dollars per unit per year, and
            percentage of EGI. Both show up in CMHC files;
            benchmarking against both catches pro forma errors
            that a single metric would miss.
          </p>
        </div>

        <div class="mt-10 overflow-x-auto rounded-lg border border-dark-gray bg-jet">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-dark-gray text-muted-foreground text-xs uppercase tracking-wide">
                <th class="px-4 py-3 text-left font-medium">Line</th>
                <th class="px-4 py-3 text-right font-medium">$/unit/yr</th>
                <th class="px-4 py-3 text-right font-medium">% EGI</th>
                <th class="px-4 py-3 text-left font-medium">Primary driver</th>
                <th class="px-4 py-3 text-left font-medium">Notes</th>
              </tr>
            </thead>
            <tbody>
              {
                opexLines.map((row) => (
                  <tr class="border-b border-dark-gray last:border-0">
                    <td class="px-4 py-3 font-medium">{row.line}</td>
                    <td class="px-4 py-3 text-right">{row.perUnit}</td>
                    <td class="px-4 py-3 text-right">{row.pctEgi}</td>
                    <td class="px-4 py-3">{row.driver}</td>
                    <td class="px-4 py-3 text-muted-foreground">{row.note}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* PROPERTY TAX CITY VIEW */}
    <section class="border-b border-dark-gray bg-jet">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Property taxes</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            The biggest cross-market variable.
          </h2>
          <p class="mt-4 text-muted-foreground">
            Property taxes vary by 2× across major CMAs for
            comparable purpose-built rental. Each jurisdiction
            also has its own affordable-housing incentive
            structure that can meaningfully lower the effective
            rate.
          </p>
        </div>

        <div class="mt-10 overflow-x-auto rounded-lg border border-dark-gray bg-obsidian">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-dark-gray text-muted-foreground text-xs uppercase tracking-wide">
                <th class="px-4 py-3 text-left font-medium">City</th>
                <th class="px-4 py-3 text-right font-medium">Typical $/unit</th>
                <th class="px-4 py-3 text-left font-medium">Municipal context</th>
              </tr>
            </thead>
            <tbody>
              {
                cityTaxes.map((row) => (
                  <tr class="border-b border-dark-gray last:border-0">
                    <td class="px-4 py-3 font-medium">{row.city}</td>
                    <td class="px-4 py-3 text-right">{row.perUnit}</td>
                    <td class="px-4 py-3 text-muted-foreground">{row.context}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* TOTAL OPEX BAND */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Total opex</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            Total opex by building archetype.
          </h2>
          <p class="mt-4 text-muted-foreground">
            Total opex as a percentage of EGI is the single
            most useful sanity check on a CMHC file. Pro formas
            showing sub-30% opex on a typical purpose-built
            rental are almost always understated.
          </p>
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {
            totalOpex.map((row) => (
              <Card className="bg-jet border-dark-gray p-6">
                <div class="text-xs uppercase tracking-wide text-star">
                  {row.range}
                </div>
                <div class="mt-1 text-lg font-semibold">{row.archetype}</div>
                <p class="mt-3 text-sm text-muted-foreground">{row.note}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    {/* FACTORS THAT MOVE OPEX */}
    <section class="border-b border-dark-gray bg-jet">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Factors</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            What moves opex up or down.
          </h2>
          <p class="mt-4 text-muted-foreground">
            Four variables explain most of the variance in total
            opex across comparable multi-unit properties.
          </p>
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <Card className="bg-obsidian border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">Age</div>
            <div class="mt-1 text-lg font-semibold">Older = higher R&M + reserves</div>
            <p class="mt-3 text-sm text-muted-foreground">
              Pre-1990 buildings typically see R&M 30–50% above
              newer stock, and replacement reserves dictated at
              the top end of the range. Mechanical replacements,
              envelope repairs, and accessibility retrofits all
              concentrate in older buildings.
            </p>
          </Card>
          <Card className="bg-obsidian border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">Utility split</div>
            <div class="mt-1 text-lg font-semibold">Landlord-pays adds 5–15%</div>
            <p class="mt-3 text-sm text-muted-foreground">
              An all-inclusive building (heat + HW + hydro paid by
              the landlord) runs 5–15% of EGI higher than a fully
              tenant-paid equivalent. Sub-metering projects are
              sometimes used as capex-plus-opex plays to shift
              this line.
            </p>
          </Card>
          <Card className="bg-obsidian border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">Building systems</div>
            <div class="mt-1 text-lg font-semibold">High-efficiency systems cut utilities</div>
            <p class="mt-3 text-sm text-muted-foreground">
              Newer HVAC, LED lighting, low-flow fixtures, and
              building automation can cut utilities 20–40% vs.
              a dated building. MLI Select energy tiers are
              scored against measurable reductions from these
              upgrades.
            </p>
          </Card>
          <Card className="bg-obsidian border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">Region</div>
            <div class="mt-1 text-lg font-semibold">Taxes and insurance drive delta</div>
            <p class="mt-3 text-sm text-muted-foreground">
              Property taxes vary by 2× between major CMAs.
              Insurance is up 5–10% year-over-year nationally,
              with regional deltas for seismic (BC) and flood
              (riverine Ontario, NB). Municipal affordable-housing
              incentives can cut taxes materially.
            </p>
          </Card>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-20 lg:px-12 lg:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-semibold tracking-tight lg:text-5xl">
            Benchmark before you submit.
          </h2>
          <p class="mx-auto mt-5 max-w-2xl text-muted-foreground">
            Running your pro forma through both $/unit and
            % of EGI lenses catches most of the common CMHC
            adjustments before they become file-stalling
            surprises.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href="/underwriting/noi-methodology">
              <Button size="lg">NOI methodology</Button>
            </a>
            <a href="/underwriting/opex">
              <Button variant="outline" size="lg">Opex overview</Button>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</DefaultLayout>
