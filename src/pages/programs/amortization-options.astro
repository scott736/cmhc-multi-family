---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { MLI_SELECT_DISCOUNTS, PREMIUM_SURCHARGES } from "@/data/cmhc";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const title = "Amortization Options — 25 to 50 Years for CMHC Multi-Unit";
const description =
  "How amortization length shapes CMHC multi-unit financing. MLI Standard 40yr existing / 50yr new construction, MLI Select tiered 40/45/50 years, the +0.25% per 5-year premium surcharge (now applies to MLI Select since July 14, 2025), and the trade-offs institutional buyers actually make.";

const amortGrid = [
  { band: "25 years or less", surcharge: 0, note: "Base — no amortization surcharge" },
  { band: "25–30 years", surcharge: 0.25, note: "One 5-year increment" },
  { band: "30–35 years", surcharge: 0.5, note: "Two 5-year increments" },
  { band: "35–40 years", surcharge: 0.75, note: "Three 5-year increments; upper end for existing" },
  { band: "40–45 years", surcharge: 1.0, note: "Four 5-year increments; MLI Select tier 2 cap" },
  { band: "45–50 years", surcharge: 1.25, note: "Five 5-year increments; new construction ceiling" },
];

const workedRows = [
  {
    amort: "25 years",
    monthly: "$58,459",
    annual: "$701,514",
    premiumSurcharge: "0.00%",
    premiumDollars: "—",
  },
  {
    amort: "30 years",
    monthly: "$53,682",
    annual: "$644,179",
    premiumSurcharge: "+0.25%",
    premiumDollars: "+$25,000",
  },
  {
    amort: "40 years",
    monthly: "$48,203",
    annual: "$578,439",
    premiumSurcharge: "+0.75%",
    premiumDollars: "+$75,000",
  },
  {
    amort: "50 years",
    monthly: "$45,435",
    annual: "$545,217",
    premiumSurcharge: "+1.25%",
    premiumDollars: "+$125,000",
  },
];

const mliStandardCaps = [
  { transaction: "MLI Standard — existing rental (purchase / refinance)", amort: "40 years" },
  { transaction: "MLI Standard — new construction", amort: "50 years (since June 2024)" },
  { transaction: "Specialized Other Shelter Models", amort: "40 years" },
];
---

<DefaultLayout title={title} description={description}>
  <div class="bg-obsidian text-foreground">
    {/* HERO */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <Badge variant="outline" className="mb-6 border-star/40 text-star">
          Amortization options
        </Badge>
        <h1 class="text-4xl font-semibold tracking-tight lg:text-6xl">
          Amortization — the fastest way to reshape the DCR and the premium.
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-muted-foreground">
          CMHC multi-unit amortization runs from 25 to 50 years depending
          on program and tier. Longer amortization reduces annual debt
          service — unlocking more loan dollars against a DCR constraint —
          but adds a premium surcharge and materially more total interest
          over the loan life. Since July 14, 2025 the amortization
          surcharge applies to MLI Select for the first time; previously
          flat MLI Select pricing made 50-year amortization effectively
          free from a premium standpoint.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/calculators/loan-sizer">
            <Button size="lg">Size the loan</Button>
          </a>
          <a href="/calculators/amortization-schedule">
            <Button variant="outline" size="lg">Amortization schedule</Button>
          </a>
        </div>
      </div>
    </section>

    {/* MAX AMORT BY PROGRAM */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Program caps</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            Maximum amortization by program and tier.
          </h2>
          <p class="mt-4 text-muted-foreground">
            MLI Standard caps are set by transaction type. MLI Select caps
            are tier-based — the same 50-year ceiling is available at tier
            3 but not at lower tiers.
          </p>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          <Card className="bg-jet border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">
              MLI Standard
            </div>
            <div class="mt-1 text-lg font-semibold">
              Set by transaction type
            </div>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-dark-gray">
                    <th class="px-2 py-2 text-left font-medium">Transaction</th>
                    <th class="px-2 py-2 text-right font-medium">Max amort</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    mliStandardCaps.map((row) => (
                      <tr class="border-b border-dark-gray/50 last:border-0">
                        <td class="px-2 py-2">{row.transaction}</td>
                        <td class="px-2 py-2 text-right font-medium">
                          {row.amort}
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </Card>

          <Card className="bg-jet border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">
              MLI Select
            </div>
            <div class="mt-1 text-lg font-semibold">
              Set by tier (points earned)
            </div>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-dark-gray">
                    <th class="px-2 py-2 text-left font-medium">Tier</th>
                    <th class="px-2 py-2 text-right font-medium">Points</th>
                    <th class="px-2 py-2 text-right font-medium">Max amort</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-b border-dark-gray/50">
                    <td class="px-2 py-2">Tier 1</td>
                    <td class="px-2 py-2 text-right font-medium">
                      {MLI_SELECT_DISCOUNTS.tier1.points}
                    </td>
                    <td class="px-2 py-2 text-right font-medium">
                      {MLI_SELECT_DISCOUNTS.tier1.maxAmort} years
                    </td>
                  </tr>
                  <tr class="border-b border-dark-gray/50">
                    <td class="px-2 py-2">Tier 2</td>
                    <td class="px-2 py-2 text-right font-medium">
                      {MLI_SELECT_DISCOUNTS.tier2.points}
                    </td>
                    <td class="px-2 py-2 text-right font-medium">
                      {MLI_SELECT_DISCOUNTS.tier2.maxAmort} years
                    </td>
                  </tr>
                  <tr>
                    <td class="px-2 py-2">Tier 3</td>
                    <td class="px-2 py-2 text-right font-medium">
                      {MLI_SELECT_DISCOUNTS.tier3.points}
                    </td>
                    <td class="px-2 py-2 text-right font-medium">
                      {MLI_SELECT_DISCOUNTS.tier3.maxAmort} years
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </Card>
        </div>
      </div>
    </section>

    {/* SURCHARGE GRID */}
    <section class="border-b border-dark-gray bg-jet">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="outline" className="mb-4 border-star/40 text-star">
            Effective July 14, 2025 — now applies to MLI Select
          </Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            The amortization surcharge grid.
          </h2>
          <p class="mt-4 text-muted-foreground">
            CMHC adds {PREMIUM_SURCHARGES.amortizationPer5Years.toFixed(2)}%
            to the base premium for every 5-year increment of amortization
            beyond 25 years. Before July 14, 2025 MLI Select was priced on a
            flat schedule and the surcharge did not apply; the risk-based
            premium overhaul made MLI Select subject to the same grid as MLI
            Standard.
          </p>
        </div>

        <div class="mt-10 overflow-x-auto rounded-lg border border-dark-gray bg-obsidian">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-dark-gray text-muted-foreground text-xs uppercase tracking-wide">
                <th class="px-4 py-3 text-left font-medium">Amortization band</th>
                <th class="px-4 py-3 text-right font-medium">Cumulative surcharge</th>
                <th class="px-4 py-3 text-left font-medium">Notes</th>
              </tr>
            </thead>
            <tbody>
              {
                amortGrid.map((row) => (
                  <tr class="border-b border-dark-gray last:border-0">
                    <td class="px-4 py-3 font-medium">{row.band}</td>
                    <td class="px-4 py-3 text-right font-medium text-star">
                      +{row.surcharge.toFixed(2)}%
                    </td>
                    <td class="px-4 py-3 text-muted-foreground">{row.note}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="mt-4 text-sm text-muted-foreground">
          The surcharge stacks on the LTV-tiered base premium and, for MLI
          Select, is applied before the tier-based discount (10% / 20% /
          30%).
        </p>
      </div>
    </section>

    {/* WORKED EXAMPLE */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Worked example</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            $10M loan at 5% — trade-off across four amortizations.
          </h2>
          <p class="mt-4 text-muted-foreground">
            Monthly payment (principal and interest, semi-annual compounding
            per Canadian convention) on a $10M loan at 5% across the four
            most common amortization choices. The premium-dollars column
            shows the surcharge on a $10M loan amount — 0.25% of $10M =
            $25,000 of added premium per 5-year increment.
          </p>
        </div>

        <div class="mt-10 overflow-x-auto rounded-lg border border-dark-gray bg-jet">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-dark-gray text-muted-foreground text-xs uppercase tracking-wide">
                <th class="px-4 py-3 text-left font-medium">Amortization</th>
                <th class="px-4 py-3 text-right font-medium">Monthly P+I</th>
                <th class="px-4 py-3 text-right font-medium">Annual debt service</th>
                <th class="px-4 py-3 text-right font-medium">Amort surcharge</th>
                <th class="px-4 py-3 text-right font-medium">Premium $ impact</th>
              </tr>
            </thead>
            <tbody>
              {
                workedRows.map((row) => (
                  <tr class="border-b border-dark-gray last:border-0">
                    <td class="px-4 py-3 font-medium">{row.amort}</td>
                    <td class="px-4 py-3 text-right">{row.monthly}</td>
                    <td class="px-4 py-3 text-right font-medium">{row.annual}</td>
                    <td class="px-4 py-3 text-right text-star">{row.premiumSurcharge}</td>
                    <td class="px-4 py-3 text-right text-muted-foreground">
                      {row.premiumDollars}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-2">
          <Card className="bg-jet border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">
              DCR capacity lift
            </div>
            <p class="mt-3 text-sm text-muted-foreground">
              At NOI $600,000 and min DCR 1.10, max annual debt service is
              $545,454. A 50-year amortization at 5% on $10M produces
              annual debt service of $545,217 — the deal passes. At
              25-year amortization the same $10M loan requires $701,514 of
              debt service and the DCR fails at 0.86. Longer amortization
              can be the difference between funding and not funding.
            </p>
          </Card>
          <Card className="bg-jet border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">
              Total interest over loan life
            </div>
            <p class="mt-3 text-sm text-muted-foreground">
              On a fully amortizing 50-year schedule the borrower pays
              approximately $17.3M in total interest versus $7.5M on a
              25-year schedule — more than double. Institutional buyers
              often amortize 25–30 years despite the 50-year option
              specifically to avoid this total-interest burden and to
              retain principal-paydown as an equity-building lever.
            </p>
          </Card>
        </div>
      </div>
    </section>

    {/* INSTITUTIONAL PRACTICE */}
    <section class="border-b border-dark-gray bg-jet">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="grid gap-10 lg:grid-cols-[1fr_1fr]">
          <div>
            <Badge variant="secondary" className="mb-4">Practice note</Badge>
            <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
              Why institutional buyers often use 25–30 years anyway.
            </h2>
            <p class="mt-4 text-muted-foreground">
              Life cos, pension funds, REITs, and large private equity
              sponsors frequently cap amortization at 25 or 30 years even
              when the program permits 50. Three reasons dominate.
            </p>
          </div>
          <Card className="bg-obsidian border-dark-gray p-6">
            <dl class="space-y-5 text-sm">
              <div>
                <dt class="text-star font-medium">Internal DCR policy</dt>
                <dd class="mt-2 text-muted-foreground">
                  Institutional underwriters typically target DCR 1.30+ rather
                  than the CMHC 1.10 floor. They don't need 50-year
                  amortization to pass DCR and prefer the faster paydown.
                </dd>
              </div>
              <div>
                <dt class="text-star font-medium">Principal paydown as equity</dt>
                <dd class="mt-2 text-muted-foreground">
                  On a 25-year amortization, roughly 27% of the original
                  balance is paid off after 10 years at 5%. On a 50-year
                  schedule that drops to roughly 8%. Principal paydown is
                  meaningful return in a low-cap-rate market.
                </dd>
              </div>
              <div>
                <dt class="text-star font-medium">Premium optimization</dt>
                <dd class="mt-2 text-muted-foreground">
                  A 25-year amortization avoids up to 1.25% of amortization
                  surcharge. On a $50M loan that is $625K of premium —
                  material even when capitalized into the loan.
                </dd>
              </div>
            </dl>
          </Card>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-20 lg:px-12 lg:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-semibold tracking-tight lg:text-5xl">
            Run the amortization trade-off, end to end.
          </h2>
          <p class="mx-auto mt-5 max-w-2xl text-muted-foreground">
            The amortization schedule calculator shows the month-by-month
            principal and interest split. The loan sizer applies the DCR and
            LTV caps together. The premium calculator combines the
            amortization surcharge with the LTV-tiered base and any MLI
            Select discount.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href="/calculators/amortization-schedule">
              <Button size="lg">Amortization schedule</Button>
            </a>
            <a href="/calculators/loan-sizer">
              <Button variant="outline" size="lg">Loan sizer</Button>
            </a>
            <a href="/calculators/premium">
              <Button variant="outline" size="lg">Premium calculator</Button>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</DefaultLayout>
