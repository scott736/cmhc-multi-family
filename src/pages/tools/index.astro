---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { LAST_UPDATED } from "@/data/cmhc";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const title = "CMHC Multi-Family Tools — Decision Support, Trackers, References";
const description =
  "Decision tools, checklists, and reference material for CMHC multi-unit financing. Eligibility wizard, program matcher, glossary, fee schedule, lender matrix, document checklist, CoI tracker, timeline tracker, rental achievement and MLI comparison.";

interface Tool {
  name: string;
  href: string;
  tagline: string;
  body: string;
}

const decisionSupport: Tool[] = [
  {
    name: "Eligibility Pre-Qualifier",
    href: "/tools/eligibility-tree",
    tagline: "8-step wizard",
    body: "Property type, unit count, construction status, borrower type, and commitments. Returns a ranked program shortlist with rationale and flags.",
  },
  {
    name: "Program Suitability Matcher",
    href: "/tools/program-matcher",
    tagline: "Priority-weighted ranking",
    body: "Rate eight factors (leverage, rate, speed, forgivable capital, amortization, recourse, commitments, affordability). Get a ranked fit score across MLI Standard, MLI Select, ACLP, AHF, CHDP.",
  },
];

const trackers: Tool[] = [
  {
    name: "Application Timeline Tracker",
    href: "/tools/timeline-tracker",
    tagline: "Gantt-style",
    body: "Nine critical-path phases from pre-application through funding. Forecast from today, or back-schedule from a target funding date.",
  },
  {
    name: "CoI & Rate-Lock Expiry",
    href: "/tools/coi-expiry",
    tagline: "Countdown + renewal",
    body: "Track CoI and rate-lock windows with days-remaining, expiry date, and a callout for the September 3 2025 transfer restriction.",
  },
  {
    name: "Rental Achievement",
    href: "/tools/rental-achievement",
    tagline: "Lease-up → holdback",
    body: "Explains rental achievement, the July 2025 holdback removal for MLI Market Rental, and projects the holdback-release date from a construction-complete date.",
  },
];

const reference: Tool[] = [
  {
    name: "Glossary",
    href: "/glossary",
    tagline: "70+ terms",
    body: "Searchable, category-filterable glossary across programs, underwriting, insurance, construction, affordability, process, lenders and legal.",
  },
  {
    name: "Fee Schedule Reference",
    href: "/tools/fee-schedule",
    tagline: "All-in cost ranges",
    body: "CMHC, appraisal, professional reports, lender, legal, construction, and provincial PST on premium. Includes a worked $10M example.",
  },
  {
    name: "Lender Comparison Matrix",
    href: "/tools/lender-matrix",
    tagline: "Sortable, filterable",
    body: "Top CMHC-approved multi-unit lenders by MUA, type, specialization, and geography. Filter by bank / monoline / trust / credit union / insurer / advisor.",
  },
  {
    name: "MLI Standard vs MLI Select",
    href: "/tools/mli-comparison",
    tagline: "Feature-by-feature",
    body: "Side-by-side matrix — LTV, amortization, DCR, premium, surcharges, commitments, recourse, and typical underwriting time.",
  },
];

const checklists: Tool[] = [
  {
    name: "Document Checklist",
    href: "/tools/doc-checklist",
    tagline: "Project × program",
    body: "Filter by project type (new construction / existing / refinance) and program. Tick off delivery progress and print a clean one-pager.",
  },
];

const groups: Array<{ title: string; subtitle: string; items: Tool[] }> = [
  {
    title: "Decision support",
    subtitle: "Pick the right program and structure.",
    items: decisionSupport,
  },
  {
    title: "Trackers",
    subtitle: "Project timelines, expiry windows, lease-up milestones.",
    items: trackers,
  },
  {
    title: "Reference",
    subtitle: "Glossary, fees, lenders, and feature-by-feature comparisons.",
    items: reference,
  },
  {
    title: "Checklists",
    subtitle: "Deliverables and documentation trackers.",
    items: checklists,
  },
];
---

<DefaultLayout title={title} description={description}>
  <div class="bg-obsidian text-foreground">
    {/* HERO */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <Badge variant="outline" className="mb-6 border-star/40 text-star">
          Tools · Current to {LAST_UPDATED}
        </Badge>
        <h1 class="text-4xl font-semibold tracking-tight lg:text-6xl">
          Decision tools, checklists, and reference material.
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-muted-foreground">
          Everything that isn't a calculator — pre-qualifiers, priority
          matchers, trackers, checklists, glossary, fees, and the lender
          matrix. Use these alongside the calculators to shortlist the
          right program, plan the timeline, and track readiness to
          funding.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/tools/eligibility-tree">
            <Button size="lg">Start with eligibility</Button>
          </a>
          <a href="/calculators">
            <Button variant="outline" size="lg">Calculators →</Button>
          </a>
        </div>
      </div>
    </section>

    {/* GROUPS */}
    {
      groups.map((g) => (
        <section class="border-b border-dark-gray">
          <div class="container border-l border-r border-dark-gray px-6 py-12 lg:px-12 lg:py-16">
            <div class="max-w-3xl">
              <Badge variant="secondary" className="mb-4">
                {g.title}
              </Badge>
              <h2 class="text-2xl font-semibold tracking-tight lg:text-3xl">
                {g.subtitle}
              </h2>
            </div>

            <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {
                g.items.map((t) => (
                  <a href={t.href} class="group">
                    <Card className="h-full bg-jet border-dark-gray p-6 transition-colors hover:border-star/50">
                      <div class="text-xs uppercase tracking-wide text-muted-foreground">
                        {t.tagline}
                      </div>
                      <div class="mt-1 text-xl font-semibold">{t.name}</div>
                      <p class="mt-3 text-sm text-muted-foreground">{t.body}</p>
                      <div class="mt-5 text-sm text-star">Open {t.name} →</div>
                    </Card>
                  </a>
                ))
              }
            </div>
          </div>
        </section>
      ))
    }

    {/* CTA */}
    <section class="border-b border-dark-gray bg-jet">
      <div class="container border-l border-r border-dark-gray px-6 py-20 lg:px-12 lg:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-semibold tracking-tight lg:text-5xl">
            Ready to model the numbers?
          </h2>
          <p class="mx-auto mt-5 max-w-2xl text-muted-foreground">
            Pair these tools with the calculators — point scorer, loan
            sizer, premium calculator, cash flow, scenario comparison
            and premium credit.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href="/calculators">
              <Button size="lg">Open calculators</Button>
            </a>
            <a href="/underwriting">
              <Button variant="outline" size="lg">Underwriting guide</Button>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</DefaultLayout>
