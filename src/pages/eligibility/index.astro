---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { LAST_UPDATED } from "@/data/cmhc";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const title = "Eligibility — Borrower, Property, and Lender Criteria";
const description =
  "CMHC multi-unit eligibility across three tiers: the borrower (covenant, experience, structure), the property (5+ units, type, condition, use), and the lender (approved-lender-only submissions since September 2024).";

const eligibilityTopics = [
  {
    slug: "borrower",
    name: "Borrower eligibility",
    tagline: "Covenant, experience, structure",
    short:
      "Who can qualify as a CMHC multi-unit borrower — for-profit, non-profit, co-op, Indigenous, government — and the covenant, liquidity, and experience tests applied.",
  },
  {
    slug: "property",
    name: "Property eligibility",
    tagline: "5+ units, purpose, condition",
    short:
      "Which properties qualify — purpose-built rental, mixed-use thresholds, specialized property types, and what disqualifies a building.",
  },
  {
    slug: "lender",
    name: "Lender eligibility",
    tagline: "Approved lenders only (Sept 2024+)",
    short:
      "Only approved CMHC lenders can submit since September 2024. Tiers, funding obligations, the September 2025 CoI restrictions, and who's approved.",
  },
];
---

<DefaultLayout title={title} description={description}>
  <div class="bg-obsidian text-foreground">
    {/* HERO */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <Badge variant="outline" className="mb-6 border-star/40 text-star">
          Eligibility · Current to {LAST_UPDATED}
        </Badge>
        <h1 class="text-4xl font-semibold tracking-tight lg:text-6xl">
          Three eligibility tiers must all clear.
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-muted-foreground">
          CMHC multi-unit eligibility is a three-tier test: the borrower
          must qualify as a covenant party, the property must qualify as
          a financeable asset, and the submitting lender must be an
          approved CMHC lender. A failure on any one tier blocks the
          file. A lender cannot submit a strong-borrower, strong-asset
          file if they themselves aren't approved; a great lender and a
          qualifying asset can't rescue a borrower who fails covenant.
        </p>
        <p class="mt-4 max-w-3xl text-lg text-muted-foreground">
          The September 2024 and September 2025 policy changes moved the
          lender tier from implicit to explicit — borrowers can no longer
          submit directly to CMHC. Picking the lender is now the first
          operational step after the property and borrower are confirmed
          eligible.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/programs">
            <Button size="lg">See the programs</Button>
          </a>
          <a href="/lenders">
            <Button variant="outline" size="lg">Approved lenders</Button>
          </a>
        </div>
      </div>
    </section>

    {/* ELIGIBILITY CARDS */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Three tiers</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            Who, what, through whom.
          </h2>
          <p class="mt-4 text-muted-foreground">
            Each eligibility page covers the test, the thresholds, and
            the edge cases that commonly derail otherwise viable files.
          </p>
        </div>

        <div class="mt-10 grid gap-4 md:grid-cols-3">
          {
            eligibilityTopics.map((t) => (
              <a href={`/eligibility/${t.slug}`} class="group">
                <Card className="h-full bg-jet border-dark-gray p-6 transition-colors hover:border-star/50">
                  <div class="text-xs uppercase tracking-wide text-muted-foreground">
                    {t.tagline}
                  </div>
                  <div class="mt-1 text-xl font-semibold">{t.name}</div>
                  <p class="mt-3 text-sm text-muted-foreground">{t.short}</p>
                  <div class="mt-5 text-sm text-star">Open {t.name} →</div>
                </Card>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    {/* WHY THREE TIERS */}
    <section class="border-b border-dark-gray bg-jet">
      <div class="container border-l border-r border-dark-gray px-6 py-16 lg:px-12 lg:py-24">
        <div class="max-w-3xl">
          <Badge variant="secondary" className="mb-4">Framework</Badge>
          <h2 class="text-3xl font-semibold tracking-tight lg:text-4xl">
            Why CMHC structures eligibility this way.
          </h2>
          <p class="mt-4 text-muted-foreground">
            Each tier maps to a different risk CMHC is underwriting —
            and a different place in the deal architecture where a
            failure shows up.
          </p>
        </div>

        <div class="mt-10 grid gap-4 md:grid-cols-3">
          <Card className="bg-obsidian border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">Tier 1</div>
            <div class="mt-1 text-lg font-semibold">Borrower = covenant risk</div>
            <p class="mt-3 text-sm text-muted-foreground">
              If the property underperforms, CMHC's claim flows through
              the borrower's guarantee. Net worth, liquidity, credit
              history, and operating experience form the covenant
              underwrite.
            </p>
          </Card>
          <Card className="bg-obsidian border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">Tier 2</div>
            <div class="mt-1 text-lg font-semibold">Property = collateral risk</div>
            <p class="mt-3 text-sm text-muted-foreground">
              The property backs the insurance. Use, condition, unit
              count, and mix must support a financeable NOI and LTV
              over a long insurance tail.
            </p>
          </Card>
          <Card className="bg-obsidian border-dark-gray p-6">
            <div class="text-xs uppercase tracking-wide text-star">Tier 3</div>
            <div class="mt-1 text-lg font-semibold">Lender = execution risk</div>
            <p class="mt-3 text-sm text-muted-foreground">
              The approved lender underwrites to CMHC standards,
              maintains the relationship, and funds in reliance on the
              CoI. Since September 2024 they must also fund ≥80% of
              approvals — operational obligation, not just submission
              access.
            </p>
          </Card>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="border-b border-dark-gray">
      <div class="container border-l border-r border-dark-gray px-6 py-20 lg:px-12 lg:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-semibold tracking-tight lg:text-5xl">
            Walk the tiers before writing the deal sheet.
          </h2>
          <p class="mx-auto mt-5 max-w-2xl text-muted-foreground">
            Confirming all three tiers are clear before submission
            saves weeks of back-and-forth. Start with the property
            and borrower; pick the lender last.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href="/eligibility/borrower">
              <Button size="lg">Borrower eligibility</Button>
            </a>
            <a href="/eligibility/property">
              <Button variant="outline" size="lg">Property eligibility</Button>
            </a>
            <a href="/eligibility/lender">
              <Button variant="outline" size="lg">Lender eligibility</Button>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</DefaultLayout>
